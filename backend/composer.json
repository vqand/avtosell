{
    "name": "5vito/backend",
    "description": "5VITO car marketplace — PHP REST API (MVC, JWT, PDO)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8080 -t public public/router.php"
    },
    "config": {
        "optimize-autoloader": true
    }
}
