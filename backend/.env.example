# Copy to .env and adjust for your environment
APP_ENV=development
APP_DEBUG=true

# CORS — your React dev server origin
CORS_ORIGIN=http://localhost:5173

# Database (XAMPP defaults: user root, empty password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fvito
DB_USER=root
DB_PASS=

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_TTL=86400

# Uploads (relative to backend/public)
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
